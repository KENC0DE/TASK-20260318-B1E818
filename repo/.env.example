# Application
APP_NAME=offline-retail-platform-api
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Security
SECRET_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_DB=app_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://app_user:app_password@db:5432/app_db

# Optional: local override for running app outside Docker
# DATABASE_URL=postgresql+psycopg2://app_user:app_password@localhost:5432/app_db
